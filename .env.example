# ================================
# WakAgenda – Configuration
# ================================

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://wakagenda_user:wakagenda_pass@localhost:5432/wakagenda_db

# --- Sécurité JWT ---
SECRET_KEY=changez-moi-avec-une-cle-secrete-longue-et-aleatoire-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Application ---
APP_NAME=WakAgenda
APP_VERSION=1.0.0
DEBUG=True

# --- CORS (origines autorisées) ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Upload (photos de profil) ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
